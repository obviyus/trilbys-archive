---
/**
 * Stats Page - Fun statistics about Yahtzee's transcripts
 * Parchment aesthetic matching the main site
 */
import { Font } from "astro:assets";
import stats from "../data/stats.json";
import "../styles/stats.css";

function formatDuration(seconds: number): string {
  const hours = Math.floor(seconds / 3600);
  const mins = Math.floor((seconds % 3600) / 60);
  if (hours > 0) {
    return `${hours}h ${mins}m`;
  }
  return `${mins}m`;
}

function formatNumber(n: number): string {
  if (n >= 1000000) {
    return `${(n / 1000000).toFixed(1)}M`;
  }
  if (n >= 1000) {
    return `${(n / 1000).toFixed(1)}K`;
  }
  return n.toLocaleString();
}

const totalHours = Math.round(stats.totalDurationSeconds / 3600);
const topProfanity = stats.profanityStats.slice(0, 8);

// --- Charts ---
const yearly = stats.yearlyStats;
const chartWidth = 700;
const chartHeight = 280;
const padding = { top: 30, right: 60, bottom: 40, left: 60 };
const plotWidth = chartWidth - padding.left - padding.right;
const plotHeight = chartHeight - padding.top - padding.bottom;

const years = yearly.map((y) => y.year);
const minYear = Math.min(...years);
const maxYear = Math.max(...years);
const xFor = (year: number) =>
  padding.left + (plotWidth * (year - minYear)) / (maxYear - minYear || 1);

interface ChartSeries {
  points: { x: number; y: number; year: number; value: number }[];
  polyline: string;
  ticks: { y: number; value: number }[];
}

function buildSeries(values: number[], tickUnit: number): ChartSeries {
  const min = Math.min(...values) * 0.9;
  const max = Math.max(...values) * 1.1;
  const yFor = (v: number) =>
    padding.top + plotHeight - (plotHeight * (v - min)) / (max - min || 1);

  const points = yearly.map((y, i) => ({
    x: xFor(y.year),
    y: yFor(values[i]),
    year: y.year,
    value: values[i],
  }));

  const ticks: { y: number; value: number }[] = [];
  const step = Math.ceil((max - min) / 4 / tickUnit) * tickUnit;
  for (let v = Math.ceil(min / tickUnit) * tickUnit; v <= max; v += step) {
    ticks.push({ y: yFor(v), value: v });
  }

  return { points, polyline: points.map((p) => `${p.x},${p.y}`).join(" "), ticks };
}

const wordsSeries = buildSeries(yearly.map((y) => y.avgWords), 50);
const wpmSeries = buildSeries(yearly.map((y) => y.avgWordsPerMinute), 5);
const swearSeries = buildSeries(yearly.map((y) => y.swearsPer1000Words), 1);

const swearArea = `${padding.left},${padding.top + plotHeight} ${swearSeries.polyline} ${padding.left + plotWidth},${padding.top + plotHeight}`;

const yearLabels: { x: number; year: number }[] = [];
const yearStep = Math.ceil((maxYear - minYear) / 8);
for (let year = minYear; year <= maxYear; year += yearStep) {
  yearLabels.push({ x: xFor(year), year });
}
if (yearLabels[yearLabels.length - 1].year !== maxYear) {
  yearLabels.push({ x: xFor(maxYear), year: maxYear });
}

// --- Word cloud ---
const cloudWords = stats.topWords.slice(0, 30);
const cloudMax = cloudWords[0].count;
const cloudMin = cloudWords[cloudWords.length - 1].count;
const shuffledCloud = [...cloudWords].sort((a, b) => {
  const hashA = a.word.charCodeAt(0) + a.word.charCodeAt(a.word.length - 1);
  const hashB = b.word.charCodeAt(0) + b.word.charCodeAt(b.word.length - 1);
  return hashA - hashB;
});

function cloudWeight(normalized: number): string {
  if (normalized > 0.85) return "weight-1";
  if (normalized > 0.65) return "weight-2";
  if (normalized > 0.45) return "weight-3";
  if (normalized > 0.25) return "weight-4";
  return "weight-5";
}

const similes = stats.similes;
const swearEverySeconds = Math.round(stats.totalDurationSeconds / stats.totalSwears);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Fun statistics from every Zero Punctuation and Fully Ramblomatic video transcript"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Statistics — Trilby's Archive" />
    <meta property="og:description" content="Fun statistics from every Zero Punctuation and Fully Ramblomatic video transcript" />
    <meta property="og:image" content="https://trilbys-archive.pages.dev/preview.jpg" />
    <meta property="og:url" content="https://trilbys-archive.pages.dev/stats" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Statistics — Trilby's Archive" />
    <meta name="twitter:description" content="Fun statistics from every Zero Punctuation and Fully Ramblomatic video transcript" />
    <meta name="twitter:image" content="https://trilbys-archive.pages.dev/preview.jpg" />
    <title>Statistics — Trilby's Archive</title>

    <Font cssVariable="--font-playfair-display" preload />
    <Font cssVariable="--font-libre-baskerville" preload />
    <Font cssVariable="--font-special-elite" preload />
  </head>

  <body>
    <div class="page-border"></div>

    <div class="container">
      <!-- Header -->
      <header>
        <a href="/" class="back-link">← Return to Archives</a>
        <div class="series-badge">Data Dive</div>
        <h1>By the Numbers</h1>
        <p class="tagline">
          {stats.totalVideos} videos, {formatNumber(stats.totalWords)} words, and {stats.totalSwears.toLocaleString()} expletives — scientifically quantified
        </p>
      </header>

      <!-- Big Stats -->
      <div class="big-stats">
        <div class="big-stat">
          <div class="big-stat-number highlight" data-count={stats.totalVideos}>{stats.totalVideos}</div>
          <div class="big-stat-label">Videos</div>
        </div>
        <div class="big-stat">
          <div class="big-stat-number" data-count={stats.totalWords} data-format="compact">{formatNumber(stats.totalWords)}</div>
          <div class="big-stat-label">Words</div>
        </div>
        <div class="big-stat">
          <div class="big-stat-number" data-count={totalHours}>{totalHours}</div>
          <div class="big-stat-label">Hours</div>
        </div>
        <div class="big-stat">
          <div class="big-stat-number" data-count={stats.avgWordsPerMinute}>{stats.avgWordsPerMinute}</div>
          <div class="big-stat-label">Words/Min</div>
        </div>
        <div class="big-stat">
          <div class="big-stat-number" data-count={stats.totalSwears}>{stats.totalSwears.toLocaleString()}</div>
          <div class="big-stat-label">Expletives</div>
        </div>
        <div class="big-stat">
          <div class="big-stat-number" data-count={stats.totalSimiles}>{stats.totalSimiles.toLocaleString()}</div>
          <div class="big-stat-label">Similes</div>
        </div>
      </div>

      <!-- Simile Roulette -->
      <div class="section-header">The Simile Engine</div>
      <div class="simile-machine">
        <div class="simile-quote" id="simile-text">…{similes[0].text}.</div>
        <div class="simile-attribution">
          — <a id="simile-link" href={`https://youtu.be/${similes[0].videoId}?t=${similes[0].t}`} target="_blank" rel="noopener">{similes[0].videoTitle}</a>
        </div>
        <button class="spin-button" id="simile-spin" type="button">Pull the Lever</button>
      </div>

      <!-- Profanity -->
      <div class="section-header">Colorful Language</div>
      <div class="panel">
        <div class="panel-header">
          <span class="panel-title">The Profanity Index</span>
          <span class="panel-note">Expletives per 1,000 words, by year</span>
        </div>
        <div class="chart-body">
          <svg class="chart-svg" viewBox={`0 0 ${chartWidth} ${chartHeight}`} preserveAspectRatio="xMidYMid meet">
            {swearSeries.ticks.map((tick) => (
              <>
                <line class="chart-grid-line" x1={padding.left} y1={tick.y} x2={chartWidth - padding.right} y2={tick.y} />
                <text class="chart-axis-label left" x={padding.left - 8} y={tick.y + 3} text-anchor="end">{tick.value}</text>
              </>
            ))}
            {yearLabels.map((label) => (
              <text class="chart-year-label" x={label.x} y={chartHeight - padding.bottom + 20} text-anchor="middle">{label.year}</text>
            ))}
            <polygon class="chart-area" points={swearArea} />
            <polyline class="chart-line words" points={swearSeries.polyline} />
            {swearSeries.points.map((p) => (
              <circle class="chart-dot words" cx={p.x} cy={p.y}>
                <title>{p.year}: {p.value} swears per 1,000 words</title>
              </circle>
            ))}
          </svg>
        </div>
      </div>

      <div class="panel">
        <div class="panel-header">
          <span class="panel-title">Profanity Leaderboard</span>
          <span class="panel-note">One expletive every {swearEverySeconds} seconds</span>
        </div>
        <div class="profanity-list">
          {topProfanity.map((p) => (
            <div class="profanity-row">
              <span class="profanity-word">{p.word}</span>
              <div class="profanity-bar-container">
                <div class="profanity-bar" style={`width: ${(p.count / topProfanity[0].count) * 100}%`}></div>
              </div>
              <span class="profanity-count">{p.count.toLocaleString()}</span>
            </div>
          ))}
        </div>
        <div class="swear-episodes">
          <div class="panel-note" style="padding: 0.5rem 0;">Sweariest episodes, per minute of runtime</div>
          {stats.sweariestEpisodes.map((ep, i) => (
            <div class="swear-episode-row">
              <span class="swear-rank">{i + 1}</span>
              <span class="swear-episode-title">
                <a href={`/transcript/${ep.id}`}>{ep.title}</a>
              </span>
              <span class="swear-episode-rate">{ep.perMinute}/min ({ep.count} total)</span>
            </div>
          ))}
        </div>
        <div class="swear-footnote">
          Meanwhile, <a href={`/transcript/${stats.cleanestEpisode.id}`}>{stats.cleanestEpisode.title}</a> contains {stats.cleanestEpisode.count === 0 ? "zero recorded expletives. Suspicious." : `only ${stats.cleanestEpisode.count}.`}
        </div>
      </div>

      <!-- Trends Over Time -->
      <div class="section-header">Trends Over Time</div>
      <div class="panel">
        <div class="panel-header">
          <span class="panel-title">Average Words & Speaking Rate by Year</span>
          <div class="chart-legend">
            <div class="legend-item">
              <span class="legend-line words"></span>
              <span>Avg Words/Video</span>
            </div>
            <div class="legend-item">
              <span class="legend-line wpm"></span>
              <span>Words/Minute</span>
            </div>
          </div>
        </div>
        <div class="chart-body">
          <svg class="chart-svg" viewBox={`0 0 ${chartWidth} ${chartHeight}`} preserveAspectRatio="xMidYMid meet">
            {wordsSeries.ticks.map((tick) => (
              <>
                <line class="chart-grid-line" x1={padding.left} y1={tick.y} x2={chartWidth - padding.right} y2={tick.y} />
                <text class="chart-axis-label left" x={padding.left - 8} y={tick.y + 3} text-anchor="end">{tick.value}</text>
              </>
            ))}
            {wpmSeries.ticks.map((tick) => (
              <text class="chart-axis-label right" x={chartWidth - padding.right + 8} y={tick.y + 3} text-anchor="start">{tick.value}</text>
            ))}
            {yearLabels.map((label) => (
              <text class="chart-year-label" x={label.x} y={chartHeight - padding.bottom + 20} text-anchor="middle">{label.year}</text>
            ))}
            <polyline class="chart-line words" points={wordsSeries.polyline} />
            <polyline class="chart-line wpm" points={wpmSeries.polyline} />
            {wordsSeries.points.map((p) => (
              <circle class="chart-dot words" cx={p.x} cy={p.y}>
                <title>{p.year}: {p.value} avg words</title>
              </circle>
            ))}
            {wpmSeries.points.map((p) => (
              <circle class="chart-dot wpm" cx={p.x} cy={p.y}>
                <title>{p.year}: {p.value} words/min</title>
              </circle>
            ))}
          </svg>
        </div>
      </div>

      <!-- Series Breakdown -->
      <div class="section-header">Series Breakdown</div>
      <div class="series-grid">
        {stats.seriesBreakdown.map((series) => (
          <div class="series-card">
            <div class="series-card-header">{series.name}</div>
            <div class="series-card-body">
              <div>
                <div class="series-stat-num">{series.count}</div>
                <div class="series-stat-label">Videos</div>
              </div>
              <div>
                <div class="series-stat-num">{formatNumber(series.avgWordsPerVideo)}</div>
                <div class="series-stat-label">Avg Words</div>
              </div>
              <div>
                <div class="series-stat-num">{series.wordsPerMinute}</div>
                <div class="series-stat-label">Words/Min</div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Records -->
      <div class="section-header">Records & Extremes</div>
      <div class="records-grid">
        <div class="record-card">
          <div class="record-label">Longest Review</div>
          <div class="record-title">
            <a href={`/transcript/${stats.longestVideo.id}`}>{stats.longestVideo.title}</a>
          </div>
          <div class="record-value">{formatDuration(stats.longestVideo.duration)}</div>
        </div>
        <div class="record-card">
          <div class="record-label">Shortest Review</div>
          <div class="record-title">
            <a href={`/transcript/${stats.shortestVideo.id}`}>{stats.shortestVideo.title}</a>
          </div>
          <div class="record-value">{formatDuration(stats.shortestVideo.duration)}</div>
        </div>
        <div class="record-card">
          <div class="record-label">Most Words</div>
          <div class="record-title">
            <a href={`/transcript/${stats.mostWords.id}`}>{stats.mostWords.title}</a>
          </div>
          <div class="record-value">{stats.mostWords.wordCount.toLocaleString()} words</div>
        </div>
        <div class="record-card">
          <div class="record-label">Fastest Talker</div>
          <div class="record-title">
            <a href={`/transcript/${stats.mostVerbose.id}`}>{stats.mostVerbose.title}</a>
          </div>
          <div class="record-value">{stats.mostVerbose.wordsPerMinute} words/min</div>
        </div>
        <div class="record-card">
          <div class="record-label">Pottiest Mouth</div>
          <div class="record-title">
            <a href={`/transcript/${stats.sweariestEpisodes[0].id}`}>{stats.sweariestEpisodes[0].title}</a>
          </div>
          <div class="record-value">{stats.sweariestEpisodes[0].perMinute} expletives/min</div>
        </div>
        <div class="record-card">
          <div class="record-label">Most Wholesome</div>
          <div class="record-title">
            <a href={`/transcript/${stats.cleanestEpisode.id}`}>{stats.cleanestEpisode.title}</a>
          </div>
          <div class="record-value">{stats.cleanestEpisode.count} expletives total</div>
        </div>
      </div>

      <!-- Pet Peeves -->
      <div class="section-header">The Grievance Registry</div>
      <div class="peeves-grid">
        {stats.petPeeves.map((peeve) => (
          <div class="peeve-card">
            <div class="peeve-count">{peeve.mentions}</div>
            <div class="peeve-label">{peeve.label}</div>
            <div class="peeve-videos">in {peeve.videos} videos</div>
          </div>
        ))}
      </div>

      <!-- Dark Souls Counter -->
      <div class="section-header">The Dark Souls of Statistics</div>
      <div class="ds-callout">
        <div class="ds-number">{stats.darkSouls.mentions}</div>
        <div class="ds-caption">
          mentions of <em>Dark Souls</em> in videos that are not about Dark Souls
        </div>
        <div class="ds-subcaption">
          {stats.darkSouls.videosMentioning} reviews found a way · only {stats.darkSouls.actualReviews} are actually about Dark Souls
        </div>
      </div>

      <!-- Fun Facts -->
      <div class="section-header">Fun Comparisons</div>
      <div class="fun-facts">
        {stats.funFacts.map((fact) => (
          <div class="fun-fact">
            <div class="fun-fact-value">{fact.value}</div>
            <div class="fun-fact-label">{fact.label}</div>
          </div>
        ))}
      </div>

      <!-- Top Words -->
      <div class="section-header">Most Used Words</div>
      <div class="words-cloud">
        {shuffledCloud.map((w) => {
          const normalized = (w.count - cloudMin) / (cloudMax - cloudMin);
          const fontSize = 0.85 + normalized * 1.75;
          return (
            <span class={`word-item ${cloudWeight(normalized)}`} style={`font-size: ${fontSize.toFixed(2)}rem`}>
              {w.word}
              <span class="word-count">{w.count.toLocaleString()}</span>
            </span>
          );
        })}
      </div>

      <!-- Vocabulary -->
      <div class="section-header">The Lexicon</div>
      <div class="vocab-stats">
        <div class="fun-fact">
          <div class="fun-fact-value">{stats.vocabulary.uniqueWords.toLocaleString()}</div>
          <div class="fun-fact-label">Distinct words deployed</div>
        </div>
        <div class="fun-fact">
          <div class="fun-fact-value">{stats.vocabulary.hapaxCount.toLocaleString()}</div>
          <div class="fun-fact-label">Words used exactly once</div>
        </div>
      </div>
      <p class="hapax-intro">A sampling of words said once in {maxYear - minYear} years, never to return:</p>
      <div class="hapax-chips">
        {stats.vocabulary.hapaxSample.map((word) => (
          <span class="hapax-chip">{word}</span>
        ))}
      </div>

      <!-- Top Games -->
      <div class="section-header">Most Mentioned Franchises</div>
      <div class="panel">
        <div class="panel-header">
          <span class="panel-title">Games & Series Referenced</span>
        </div>
        <div class="games-grid">
          {stats.topMentionedGames.slice(0, 16).map((g) => (
            <div class="game-item">
              <span class="game-name">{g.game}</span>
              <span class="game-count">{g.count} mentions</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Footer -->
      <footer>
        <p>
          <a href="/">Search the archives</a> · <a href="https://github.com/obviyus/trilbys-archive">View source</a>
        </p>
        <p class="colophon">
          Statistics computed from {stats.totalVideos} video transcripts spanning {maxYear - minYear} years of gaming critique.
        </p>
      </footer>
    </div>

    <script define:vars={{ similes }}>
      const quoteEl = document.getElementById("simile-text");
      const linkEl = document.getElementById("simile-link");
      let current = 0;

      function spin() {
        let i = current;
        while (i === current) {
          i = Math.floor(Math.random() * similes.length);
        }
        current = i;
        const s = similes[i];
        quoteEl.textContent = `…${s.text}.`;
        linkEl.textContent = s.videoTitle;
        linkEl.href = `https://youtu.be/${s.videoId}?t=${Math.max(0, s.t - 2)}`;
        quoteEl.classList.remove("spinning");
        void quoteEl.offsetWidth;
        quoteEl.classList.add("spinning");
      }

      document.getElementById("simile-spin").addEventListener("click", spin);
      spin();
    </script>

    <script>
      function formatCount(value: number, mode: string | undefined): string {
        if (mode === "compact") {
          if (value >= 1000000) return `${(value / 1000000).toFixed(1)}M`;
          if (value >= 1000) return `${(value / 1000).toFixed(1)}K`;
        }
        return Math.round(value).toLocaleString();
      }

      const reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
      for (const el of document.querySelectorAll<HTMLElement>("[data-count]")) {
        const target = Number(el.dataset.count);
        const mode = el.dataset.format;
        if (reduced) continue;
        const start = performance.now();
        const duration = 1200;
        const tick = (now: number) => {
          const progress = Math.min(1, (now - start) / duration);
          const eased = 1 - (1 - progress) ** 3;
          el.textContent = formatCount(target * eased, mode);
          if (progress < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      }
    </script>
  </body>
</html>
